# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application Configuration
NEXT_PUBLIC_APP_NAME=Threadz
NEXT_PUBLIC_APP_DESCRIPTION=Create Your Own Fashion

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_GENERATION=true
NEXT_PUBLIC_ENABLE_COMMUNITY_DESIGNS=true

# Analytics (Optional - for future implementation)
NEXT_PUBLIC_GA_ID=your-google-analytics-id
NEXT_PUBLIC_HOTJAR_ID=your-hotjar-id

# Payment (Optional - for future implementation)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
