# Development Environment Variables
# Copy this file to .env for local development

# Application
ENVIRONMENT=development
DEBUG=true
APP_NAME=Threadz
VERSION=1.0.0

# Database Configuration (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./sql_app.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production-use-256-bit-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SSL Configuration (for development)
SSL_CERT_PATH=./ssl/localhost.crt
SSL_KEY_PATH=./ssl/localhost.key
TRUSTED_HOSTS=localhost,127.0.0.1

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=uploads/designs

# Payment Gateway (Razorpay - Test Mode)
RAZORPAY_KEY_ID=your_test_razorpay_key_id
RAZORPAY_KEY_SECRET=your_test_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_test_webhook_secret

# AI Generation (Optional - for future implementation)
STABILITY_API_KEY=your-stability-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Error Tracking (Optional)
SENTRY_DSN=your-sentry-dsn-for-development

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Cloud Storage (Optional - for production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=threadz-uploads
AWS_REGION=us-east-1
